#[test]
fn test_notion_sync_get_pending_items() {
    let temp_file = NamedTempFile::new().unwrap();
    let db_path = temp_file.path();

    let conn = Connection::open(db_path).unwrap();
    init_schema(&conn).unwrap();

    let notion_sync = NotionSync::new(
